# Expo SDK 56+ made its own native `expo/fetch` the default global fetch
# implementation. It has a known bug that corrupts the OAuth PAR request body
# used by @atproto/oauth-client, breaking Bluesky sign-in with a
# "use_dpop_nonce" error that never gets retried correctly.
# See: https://github.com/expo/expo/issues/45909
# Revert to React Native's built-in fetch until Expo fixes this upstream.
EXPO_PUBLIC_USE_RN_FETCH=1
